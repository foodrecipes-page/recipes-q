{
  "title": "Quick Fix Mediterranean Citrus Crumble",
  "description": "A citrusy, dense dish that combines fresh herbs and zest with baking powder for a quick-fix recipe perfect for breakfast or a light meal.",
  "cuisine": "Mediterranean",
