  "meal": "breakfast",
  "ingredients": [
    {
      "name": "1 cup almond flour",
      "amount": "cup"
    },
    {
      "name": "2 tablespoons grated orange zest",
      "amount": ""
    },
    {
      "name": "1/4 teaspoon ground cumin",
      "amount": ""
    },
    {
      "name": "1/4 teaspoon garlic powder",
      "amount": ""
    },
    {
      "name": "Pinch of salt",
      "amount": ""
    },
    {
      "name": "1 cup diced canned sweet peaches",
      "amount": ""
    },
    {
      "name": "2 tablespoons honey or agave nectar",
      "amount": ""
    }
  ],
  "instructions": [
    "Preheat air fryer to 350°F (175°C).",
    "In a mixing bowl, combine almond flour, orange zest, cumin, garlic powder, and salt.",
    "Add in the diced sweet peaches and honey or agave nectar. Mix until well combined.",
    "Transfer mixture into an air fryer safe dish.",
    "Spray inside with cooking spray or lightly grease if using a baking dish.",
    "Bake for 15-20 minutes, stirring halfway through.",
    "Allow to cool before serving."
